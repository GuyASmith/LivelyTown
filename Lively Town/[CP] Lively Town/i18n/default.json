{
	// // CONFIG // //
	"Config.EnableLuauBridge.name": "Enable Luau Bridge Fix",
	"Config.EnableLuauBridge.description": "The Luau festival always shows the bridge on the beach as broken, even if the bridge was repaired. This fixes that.",
	"Config.EnableNightMarketBridge.name": "Enable Night Market Bridge Fix",
	"Config.EnableNightMarketBridge.description": "The Night Market festival always shows the bridge on the beach as broken, even if the bridge was repaired. This fixes that.",
	"Config.EnableEventConsistency.name": "Enable Event Consistency",
	"Config.EnableEventConsistency.description": "Makes events and dialogue more responsive to things that have happened.",
	"Config.EnableHighFriendshipEvents.name": "Enable High Friendship Events",
	"Config.EnableHighFriendshipEvents.description": "ALPHA FEATURE: This allows you to experience some 10-14 heart events with the folks you aren't married to if you have already settled down with someone else.",
	"Config.SpouseNoun.name": "Spouse Noun",
	"Config.SpouseNoun.description": "Only matters if you have the Gender Neutrality mod by Hanatsuki and enable High Friendship Events; has to be copied here since you can't reference other mods' settings. This is the word which is used to describe your marital status. Examples: husband, wife, spouse, partner, etc. Can include multiple separated by commas. If you enable FemLanguage, use 'Wife', and if you enable MascLanguage, use 'Husband'. Default is 'Partner'.",
	"Config.EnableFundraiserBooks.name": "Enable Haley Fundraiser Books",
	"Config.EnableFundraiserBooks.description": "Haley fundraises to get new books for the kids at 14 hearts. This neatens up the library and adds fuller shelves after Lewis is pressured by the townsfolk to do more with their business taxes. Automatically ignored if Stardew Valley Expanded is installed.",
	"Config.EnableCarolineCorner.name": "Enable Caroline's Corner Shop",
	"Config.EnableCarolineCorner.description": "Allows Caroline to open her corner store with tea, out of season seeds, flowers, fiber, and decoratives.",
	"Config.EnableShanesEggs.name": "Enable Shane's Eggs",
	"Config.EnableShanesEggs.description": "A little change to Pierre's that adds an egg display and he sells eggs once you've gotten Shane's 8 heart event. Also adds diaglogue for after the event about that.",
	"Config.EggDisplay.name": "Egg Display",
	"Config.EggDisplay.description": "Entirely visual, determines how eggs are visually shown as added to Pierre's shop. Set to 'None' if you have other mods creating conflicts. Requires Shane's Eggs to be set to 'true'.",
	"Config.EnableEvelynsGardening.name": "Enable Evelyn's Gardening",
	"Config.EnableEvelynsGardening.description": "ALPHA FEATURE: Makes the tree outside of Evelyn's house a cherry tree and gives her more plant pots. She might give you jelly and cherries as gifts, some people reference it, and optionally you'll be able to see them on the tree. If 'DialogueOnly', you'll only have the dialogue and gifts; use this option if you have recolor mods installed. Credit to dollynhoevida on Nexus for the idea.",
	"Config.EnableGiveClintGrowth.name": "Enable Give Clint Growth - (INCOMPLETE)",
	"Config.EnableGiveClintGrowth.description": "ALPHA FEATURE, INCOMPLETE, ON HOLD UNTIL 1.7: Makes Clint less creepy and grow a little. He normally stagnates at 6 hearts, if you even get that event. This expands beyond that.",
	
	
	// // UI Info Suite Icon Tooltip // //
	"Compat.CarolineCornerIconTooltip": "Caroline Corner Shop in Pierre's is open",
	
	
	// EVENTS //
	// // Caroline Corner // //
	"CarolineCorner.Event.Dialogue1": "I just think it would be nice to sell tea in the shop.$0#$b#While I'm at it, we could also try to sell the excess festival stock in the basement.$s",
	"CarolineCorner.Event.Dialogue2": "We do have limited space in the storeroom...$s",
	"CarolineCorner.Event.Dialogue3": "It's our basement and it doesn't feel like 'ours' because of all of your seasonal stock.$u#$b#I'd like just a corner of it.$s",
	"CarolineCorner.Event.Dialogue4": "They don't seem to have noticed me.#Probably better not to disturb them.",
	"CarolineCorner.Event.Dialogue5": "*sigh* Pierre, I just want to participate.$0#$b#I have a lot more free time now that our daughter's all grown up, and want to do something with the green thumb I've grown.$h",
	"CarolineCorner.Event.Dialogue6": "Your... thumb is green?$0",
	"CarolineCorner.Event.Dialogue7": "...$0",
	"CarolineCorner.Event.Dialogue8": "Grown? Like a plant monster bit it off and you grew a plant finger$0",
	"CarolineCorner.Event.Dialogue9": "...$s",
	"CarolineCorner.Event.Dialogue10": "D'Oh!$h",
	"CarolineCorner.Event.Dialogue11": "You know, I could take more than just a corner of the basement.$h",
	"CarolineCorner.Event.PostDialogue": "I think my wife has an idea for the shop...$0#$b#But I just know I'm going to be the one moving all the heavy shelves.$s#$e#Anyway, what do you need?$0",
	// // // Piper Rewrite compat
	"CarolineCorner.Event.PiperCompat.Dialogue5": "*sigh* Piper dear, I just want to participate in the shop.$0#$b#I have a lot more free time now that our daughter's all grown up, and want to do something with the green thumb I've grown.$h",
	"CarolineCorner.Event.PiperCompat.Dialogue6": "Carrie, hasn't it been two weeks since you last dyed your hair?$0",
	"CarolineCorner.Event.PiperCompat.Dialogue7": "...you would know about that wouldn't you?$h",
	"CarolineCorner.Event.PiperCompat.Dialogue8": "Haha!$h",
	"CarolineCorner.Event.PiperCompat.Dialogue9": "Was that... flirting for them?",
	"CarolineCorner.Event.PiperCompat.PostDialogue": "I think my wife has an idea for the shop...$0#$b#But I just know I'm going to be the one moving everything.$s#$e#Anyway, what do you need?$0",
	
	
	// // Shane's Eggs // //
	"VanillaSimilar.Event.ShanesEggs.Dialogue1": "Uncle Shane's in the barn. He said... Uh... He said to tell you he wants to show you something.",
	"VanillaSimilar.Event.ShanesEggs.Dialogue2": "That should do it...$6",
	"VanillaSimilar.Event.ShanesEggs.Dialogue3": "It's the perfect home for you hens...$8#$b#We'll have the best eggs in the whole valley!$8#$b#Fresh and healthy, with rich golden yolks. Not like those pale, sickly Joja eggs...$8",
	"VanillaSimilar.Event.ShanesEggs.Dialogue4": "...*sigh*...$9#$b#...You know, Charlie... I was thinking... $9#$b#A guy like me is always teetering on the edge of despair... know what I mean?$9#$b#...But you and the other hens are going to keep me upright from now on... I know it.$9#$b#...$9#$b#What's wrong... too much pressure? *chuckle*$8",
	"VanillaSimilar.Event.ShanesEggs.Dialogue5": "Hey, @... so, what do you think?$l",
	"VanillaSimilar.Event.ShanesEggs.Dialogue6": "My special blue hens... I've been raising them in secret for the last few months.$6",
	"VanillaSimilar.Event.ShanesEggs.Dialogue7": "I... Well, I won't be living here forever, and I wanted to pass something on to Jas. I've been teaching her how to care for them.$6#$b#...I want to feel like I'm not just a leech on the world. I want to contribute somehow, even in a small way like this.",
	"VanillaSimilar.Event.ShanesEggs.PostDialogue": "I think Marnie should start selling the extra eggs.$0#%revealtasteShane176#$e#Now that she has the blue hens, you can probably get baby blue chicks too. They're precious.$h",
	
	
	// // Event Consistency // //
	"EventConsistency.Event.AlexHighHeart.Dialogue16": "I'm having a lot of fun. And it's good for business!$h",
	// there aren't many parts of that right now
	
	// // Vanilla Copies for HFEs // //
	// // Alex asks for money
	"VanillaCopy.Event.AlexAskForMoney.Dialogue1": "Hey, @. Before you head out...#$b#I hate to ask this... but can I have 5,000g?#$b#It's for a secret project I'm working on... I know we have a joint bank account, but I thought I should ask anyway.",
	"VanillaCopy.Event.AlexAskForMoney.Dialogue2": "Give Alex 5,000g for his secret project?",
	"VanillaCopy.Event.AlexAskForMoney.DialogueOption1": "Yes",
	"VanillaCopy.Event.AlexAskForMoney.DialogueOption2": "No",
	"VanillaCopy.Event.AlexAskForMoney.Dialogue3": "Really? You won't spare a measly 5,000g to make me happy?$a#$b#I didn't know you were such a cheapskate...$s",
	"VanillaCopy.Event.AlexAskForMoney.Dialogue4": "I just wanted to have a little fun...$s",
	"VanillaCopy.Event.AlexAskForMoney.BadPostDialogue": "I don't want to talk to you right now...$s",
	// // Alex High Heart Saloon event
	"VanillaCopy.Event.AlexHighHeart.Dialogue1": "Big play!",
	"VanillaCopy.Event.AlexHighHeart.Dialogue2": "Score!",
	"VanillaCopy.Event.AlexHighHeart.Dialogue3": "There we go!",
	"VanillaCopy.Event.AlexHighHeart.Dialogue4": "Atta boy!",
	"VanillaCopy.Event.AlexHighHeart.Dialogue5": "Hey, @! You made it!$h",
	"VanillaCopy.Event.AlexHighHeart.Dialogue6": "So... what do you think?",
	"VanillaCopy.Event.AlexHighHeart.Dialogue7": "I've been thinking... You know how I used to dream of being an athlete someday?#$b#Well, my life ended up turning out a bit different... $9#$b#I'm happy, though, don't get me wrong!$h#$b#...But I thought it would be cool to have a place where us guys could hang out and watch the Sunday game. Gus liked the idea so much he offered me part of his back room!#$b#This way, I get to keep part of 'the dream' alive, in a small way.",
	"VanillaCopy.Event.AlexHighHeart.Dialogue8": "You did good, son. I could watch this at home, but coming here makes me feel young again!$h",
	"VanillaCopy.Event.AlexHighHeart.Dialogue9": "Thanks, Grandpa.",
	"VanillaCopy.Event.AlexHighHeart.Dialogue10": "I'm happy for an excuse to get out of the house, and take my mind off things.",
	"VanillaCopy.Event.AlexHighHeart.Dialogue11": "Same",
	"VanillaCopy.Event.AlexHighHeart.Dialogue12": "I'm having a lot of fun. And it's good for business!$h#$b#Though maybe not so good for Shane's liver...$s",
	"VanillaCopy.Event.AlexHighHeart.Dialogue13": "Hey!",
	"VanillaCopy.Event.AlexHighHeart.Dialogue14": "It seems the guys have a new Sunday tradition.",
	"VanillaCopy.Event.AlexHighHeart.Dialogue15": "5,000g well spent!",
	"VanillaCopy.Event.AlexHighHeart.PostDialogue": "Thanks again for the money, @. It was a fun project for me, and all the guys seem happy with it!",
	
	// // Elliot High Heart start event
	"VanillaCopy.Event.ElliotBookTourStart.Dialogue1": "@! I've just received the most exciting news!",
	"VanillaCopy.Event.ElliotBookTourStart.Dialogue2": "It's very short notice... but I've been invited to do a reading tour for my book, '%book'!",
	"VanillaCopy.Event.ElliotBookTourStart.Dialogue3": "...I'll be out of town for a week. Will you be okay?$s",
	"VanillaCopy.Event.ElliotBookTourStart.DialogueOption1": "Yes, I'll be fine.",
	"VanillaCopy.Event.ElliotBookTourStart.DialogueOption2": "I'll be happy as a clam!",
	"VanillaCopy.Event.ElliotBookTourStart.DialogueOption3": "Don't go!",
	"VanillaCopy.Event.ElliotBookTourStart.Dialogue4": "I'll miss you very much, my dear.#$b#And I'll write to you every day, of course!",
	"VanillaCopy.Event.ElliotBookTourStart.Dialogue5": "Hah... good one. Now, don't get too excited...$8#$b#I'll be sure to write to you every day. I'll miss you!",
	"VanillaCopy.Event.ElliotBookTourStart.Dialogue6": "But, my dear... This is a rare opportunity for me. I must go!$s#$b#Please don't make me feel guilty about this. I'll write to you every day, and I'll be back before you know it.",
	"VanillaCopy.Event.ElliotBookTourStart.Dialogue7": "I leave early tomorrow morning...#$b#I need to pack!$8",
	"VanillaCopy.Event.ElliotBookTourStart.PostDialogue": "Don't let me forget my hairbrush, my hairspray, my fine-tooth comb, and my pomegranate conditioner!",
	
	// // Leah High Heart start event
	"VanillaCopy.Event.LeahPaintingStarter.Dialogue1": "Hey, @. I have an idea...#$b#I want you to meet me in Cindersap Forest tomorrow, at noon.#$b#I'm gonna teach you how to paint!$h",
	"VanillaCopy.Event.LeahPaintingStarter.Dialogue2": "If the weather's bad, we'll do it the next day. Okay?",
	"VanillaCopy.Event.LeahPaintingStarter.PostDialogue": "It'll be nice to explore your creative side a bit more, don't you think?",
	
	// // Emily High Heart start event
	"VanillaCopy.Event.EmilyClothingStarter.Dialogue1": "Hey, honey... before you get to work today, do you have a moment?#$b#I've been working on something special for you... but I need a little help finishing it.",
	"VanillaCopy.Event.EmilyClothingStarter.Dialogue2": "It's a secret, so I can't tell you what it is... but could you bring me 200 pieces of fiber?",
	"VanillaCopy.Event.EmilyClothingStarter.Dialogue3": "That's all I need! Just bring the 200 fiber by when you have a chance... no rush!",
	"VanillaCopy.Event.EmilyClothingStarter.PostDialogue": "No peeking! You'll see the end result soon.",
	
	// // Haley High Heart start event
	"VanillaCopy.Event.HaleyHighHeartStarter.Dialogue1": "Ms. Penny? The cover fell off my math book...$s",
	"VanillaCopy.Event.HaleyHighHeartStarter.Dialogue2": "Let me see...$s",
	"VanillaCopy.Event.HaleyHighHeartStarter.Dialogue3": "Oh no... Your books are falling apart...$s#$b#They're just too old.$s",
	"VanillaCopy.Event.HaleyHighHeartStarter.Dialogue4": "...But new books are expensive, so we'll just have to make do with what we have...$s",
	"VanillaCopy.Event.HaleyHighHeartStarter.Dialogue5": "Does this mean I don't have to do my homework?$h",
	"VanillaCopy.Event.HaleyHighHeartStarter.PostDialogue": "I've been thinking about cake a lot lately...",
	// // Haley has an idea
	"VanillaCopy.Event.HaleyHasAnIdea.Dialogue1": "Hi, honey.#$b#Hey... I have an idea... I want to get everyone together for a charity cake-walk.",
	"VanillaCopy.Event.HaleyHasAnIdea.Dialogue2": "Uh... It's kind of like musical chairs, but everyone wins and gets cake! You'll see...$h#$b#It'll be on the next sunny day in the town square.#$b#Um... would you mind bringing a chocolate cake?",
	"VanillaCopy.Event.HaleyHasAnIdea.Dialogue3": "Do you agree to bring chocolate cake?",
	"VanillaCopy.Event.HaleyHasAnIdea.DialogueOption1": "Yes",
	"VanillaCopy.Event.HaleyHasAnIdea.DialogueOption2": "Yes (begrudgingly)",
	"VanillaCopy.Event.HaleyHasAnIdea.Dialogue4": "Great! I'll meet you in the town square tomorrow, weather permitting.$h",
	"VanillaCopy.Event.HaleyHasAnIdea.Dialogue5": "What's up with the snarky attitude?$3#$b#Fine. You're going to show up tomorrow with a chocolate cake, or else you're in the dog house. You like that better?$3",
	"VanillaCopy.Event.HaleyHasAnIdea.PostDialogue": "I'm bringing a pink cake.",
	// // Haley Cakewalk event
	"VanillaCopy.Event.HaleyCakewalk.Dialogue1": "Hey! Oh, good, you brought the cake!...",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue2": "Seems really moist. Thanks, @.",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue3": "It's a pretty good turnout, huh?",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue4": "Um... Haley? When do we stop? M... My legs... *pant* *pant*$s",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue5": "Whoops! Forgot to blow the whistle.$h",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue6": "Alright! Everyone should be standing on a numbered square.",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue7": "I am!",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue8": "Yep",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue9": "That's right",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue10": "Your number determines which cake you win!#$b#Okay, let's see who gets what...",
	"HighFriendshipEvents.Event.HaleyCakewalk.Dialogue11": "Okay, Let's see here... #$b#Caroline, what number are you? Okay... you've won...#$b#Mayor Lewis' cave carrot loaf... with extra fiber!",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue12": "Oh, joy",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue13": "Emily, you've got...#$b#Pam's chocolate stout cupcakes, with aged bourbon buttercream.",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue14": "Nice!",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue15": "You're in for a treat, kid.$h",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue16": "Next... Jas, you've got...#$b#Clint's wild horseradish cobbler.",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue17": "It's an old family recipe. I baked it right in the smelting oven.#$b#Oh, um... I may have burnt the bottom a little, so... uh... you might have to peel off a layer of charred matter. But the rest is totally edible.",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue18": "Uh, Okay... Next up is Vincent. We've got...#$b# Robin's Triple syrup n' cream strawberry sugar log!",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue19": "Oh no...",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue20": "Next up, Jodi. You're gonna take home...#$b# Emily's organic red velvet cake... colored with beets!",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue21": "Yum!",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue22": "...and last, but not least: Pam! You're the lucky winner of my husband's deluxe chocolate cake.^...and last, but not least: Pam! You're the lucky winner of my wife's deluxe chocolate cake.",
	"VanillaCopy.Event.HaleyCakewalk.GenderNeutralCompat.Dialogue22": "...and last, but not least: Pam! You're the lucky winner of my {{Lowercase:{{Random: {{SpouseNoun}} }} }}'s deluxe chocolate cake.",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue23": "Thanks, kid",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue24": "Thanks everyone for joining in. We raised over 5,000g!",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue25": "What's the money for, anyway? You buyin' a new purse?",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue26": "Actually... it's for Penny.",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue27": "Penny, the other day I overheard you talking with Jas and Vincent about their school books. It sounded like you could use some help...",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue28": "New books!",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue29": "Did you hear that, kids? You're getting brand new school books!",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue30": "I don't know what to say... Thank you so much.$h#$b#...to both of you!$h",
	"VanillaCopy.Event.HaleyCakewalk.Dialogue31": "Hey Lewis... since we're funding education without touching the town's coffers, you'll be lowering our business tax, right?$h",
	"VanillaCopy.Event.HaleyCakewalk.PostDialogue": "It was a big success! Thanks for helping out, honey.",
	
	// // Shane High Heart event 1
	"VanillaCopy.Event.ShaneHighHeart1.Dialogue1": "Phew... that was fun.$h#$b#Haven't had a session like that in a while... *urp*",
	"VanillaCopy.Event.ShaneHighHeart1.Dialogue2": "Welp... I'm all sweaty. Better head back home.",
	"VanillaCopy.Event.ShaneHighHeart1.Dialogue3": "Oh no... this doesn't look good.$s",
	"VanillaCopy.Event.ShaneHighHeart1.Dialogue4": "@? You'd better keep your eye on him... next time you catch him coming out of the Saloon, you should say something...$s",
	"VanillaCopy.Event.ShaneHighHeart1.PostDialogue": "Is everything alright, @? You seem worried...",
	// // Shane High Heart event 2
	"VanillaCopy.Event.ShaneHighHeart2.Dialogue1": "*urp*",
	"VanillaCopy.Event.ShaneHighHeart2.Dialogue2": "Oh! Hey @. I was just on my way home...",
	"VanillaCopy.Event.ShaneHighHeart2.Dialogue3": "'Were you drinking?'... No!$a#$b#Why would you think that?$a",
	"VanillaCopy.Event.ShaneHighHeart2.Dialogue4": "Hmph..",
	"VanillaCopy.Event.ShaneHighHeart2.PostDialogue": "...$a",
	// // Shane High Heart event 3
	"VanillaCopy.Event.ShaneHighHeart3.Dialogue1": "Okay... I'm ready for another round!",
	"VanillaCopy.Event.ShaneHighHeart3.Dialogue2": "Alright... we've caught him in the act. Now let's confront him. Take a deep breath... $s",
	"VanillaCopy.Event.ShaneHighHeart3.Dialogue3": "Arrgh!",
	"VanillaCopy.Event.ShaneHighHeart3.Dialogue4": "So close...",
	"VanillaCopy.Event.ShaneHighHeart3.Dialogue5": "Oh, hey! Didn't know I had an audience.$h",
	"VanillaCopy.Event.ShaneHighHeart3.Dialogue6": "Shane... this is what you've been doing in here?$s",
	"VanillaCopy.Event.ShaneHighHeart3.Dialogue7": "Yeah! What did you think?$h",
	"VanillaCopy.Event.ShaneHighHeart3.Dialogue8": "I'm completely addicted to this game...#$b#I can't help but play round after round...",
	"VanillaCopy.Event.ShaneHighHeart3.Dialogue9": "I've even reached the number three spot in the global leaderboards... you might say I'm one of the best.$h",
	"VanillaCopy.Event.ShaneHighHeart3.Dialogue10": "But... these cans...$s",
	"VanillaCopy.Event.ShaneHighHeart3.Dialogue11": "Oh, that's just Joja Cola... Yeah, yeah, I know... It's bad for the teeth. But it helps me focus...",
	"VanillaCopy.Event.ShaneHighHeart3.Dialogue12": "Wait... did you guys think I was drinking beer?$a",
	"VanillaCopy.Event.ShaneHighHeart3.Dialogue13": "@? I told you I hadn't been drinking...$a",
	"VanillaCopy.Event.ShaneHighHeart3.DialogueOption1": "We were worried...",
	"VanillaCopy.Event.ShaneHighHeart3.DialogueOption2": "I'm sorry, I should've believed you",
	"VanillaCopy.Event.ShaneHighHeart3.Dialogue14": "...That's alright, @. You're just looking out for me. I get it.#$b#Look... I know I haven't been perfect... but, I'm trying my best... and I'm gonna keep trying. So you don't have to worry about me.#$b#My life is better now than it's ever been. I'm not in such a dark place anymore...",
	"VanillaCopy.Event.ShaneHighHeart3.Dialogue15": "You know, when I'm playing this game, I become so focused that I can't think about anything else. It really helps when I've got 'the urge'...",
	"VanillaCopy.Event.ShaneHighHeart3.Dialogue16": "Anyway... I'll just... eh... play ONE more round and head home. Okay?",
	"VanillaCopy.Event.ShaneHighHeart3.PostDialogue": "You guys must have been really confused when you came in and saw me in front of the arcade machine!$h",
	
	// // Sam High Heart event 1
	"VanillaCopy.Event.SamHighHeart1.Dialogue1": "",
	// // Sam High Heart event 2
	"VanillaCopy.Event.SamHighHeart2.Dialogue1": "",
	// // Sam High Heart event 3
	"VanillaCopy.Event.SamHighHeart3.Dialogue1": "",
	// // Sam High Heart event 4
	"VanillaCopy.Event.SamHighHeart4.Dialogue1": "",
	
	
	// // High Friendship Events // //
	// // Shane Sobriety
	"HighFriendshipEvents.Event.ShaneSobriety.Dialogue1": "You're my closest friend... you should trust me. I've always been honest with you about my problems.$a#$b#Look... I know I haven't been able to quit cold turkey... but, I'm trying my best... and I'm getting a lot healthier.#$b#My life is better now than it's ever been. I'm not in such a dark place anymore...",
	"HighFriendshipEvents.Event.ShaneSobriety.Dialogue2": "You know, when I'm playing this game, I become so focused that I can't think about anything else. It really helps when I've got 'the urge'...",
	"HighFriendshipEvents.Event.ShaneSobriety.Dialogue3": "Anyway... I'll just... eh... play ONE more round and head home. Okay?",
	"HighFriendshipEvents.Event.ShaneSobriety.PostDialogue": "You guys must have been really confused when you came in and saw me in front of the arcade machine!$h",
	
	// // Alex High Heart HFE-specific
	"HighFriendshipEvents.Event.AlexAskForMoney.Dialogue5": "Hey, @. Before you head out...#$b#I hate to ask this... but can I have 5,000g?#$b#It's for a secret project I'm working on...#$b#Don't worry, it's for a community cause!$h",
	"HighFriendshipEvents.Event.AlexAskForMoney.Dialogue6": "Great! Swing by the Saloon on Sunday and I'll show you the end result!$h",
	// // Alex High Heart Town reminder
	"HighFriendshipEvents.Event.AlexHighHeartReminder.Dialogue1": "It's Sunday... I should swing by the saloon later and see what Alex has been up to!",
	
	// // Emily High Heart start HFE-specific
	"HighFriendshipEvents.Event.EmilyClothingStarter.Dialogue1": "Hey, @... I wanted to stop you before you started work today. You have a moment?#$b#I wanted to work on something special this week... but I need a little help finishing it.",
	"HighFriendshipEvents.Event.EmilyClothingStarter.Dialogue2": "It's a secret, so I can't tell you what it is... but could you bring me a diamond?",
	"HighFriendshipEvents.Event.EmilyClothingStarter.Dialogue3": "That's all I need! Just bring the diamond by when you have a chance... no rush, just bring it to my place.",
	// // Emily High Heart complete HFE
	"HighFriendshipEvents.Event.EmilyClothingFinisher.Dialogue1": "Did you bring the diamond?",
	"HighFriendshipEvents.Event.EmilyClothingFinisher.Dialogue2": "Thanks a billion!$h#$b#I need this for my own fetch-quest. A sewing friend from the desert needs this for some showy bling on a dress project.#$b#In return, I've got something for you I would only give someone I am really grateful for.",
	"HighFriendshipEvents.Event.EmilyClothingFinisher.Dialogue3": "But... it's not ready yet and I'll send it to you tomorrow.#$b#Don't worry, you'll love it.$h",
	"HighFriendshipEvents.Event.EmilyClothingFinisher.PostDialogue": "No peeking, remember?",
	
	// // Haley has an idea HFE
	"HighFriendshipEvents.Event.HaleyHasAnIdea.Dialogue1": "Hi, @.#$b#Hey... Sorry to barge in, but I have an idea... I want to get everyone together for a charity cake-walk.",
